# TicketSec Arm64 Dashboard — Environment Template
# Copy this file to .env and adjust values for your deployment.

# FastAPI backend base URL (no trailing path)
VITE_API_BASE_URL=http://3.23.60.61:8000

# CORS allow-list for the FastAPI backend.
# Demo period: include localhost dev/preview origins and the static demo origin.
# Post-demo: replace with the production static-host origin only.
# Example: ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173,https://your-demo-origin.example
ALLOW_ORIGINS=*

# Public /predict rate limit (requests per minute, per client IP).
PREDICT_RATE_LIMIT_RPM=60
