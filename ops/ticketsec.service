[Unit]
Description=TicketSec Arm64 FastAPI classifier
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/ticketsec
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/ubuntu/ticketsec/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
MemoryMax=700M

[Install]
WantedBy=multi-user.target
